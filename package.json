{
  "name": "poke-cli",
  "version": "1.0.0",
  "description": "CLI for Pokémon save files",
  "keywords": [
    "poke",
    "cli",
    "savefile"
  ],
  "license": "ISC",
  "author": "Breno Gomes",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts"
  },
  "bin": {
    "poke-cli": "src/cli.ts"
  },
  "files": [
    "src"
  ],
  "engines": {
    "bun": ">=1.0"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "dev": "bun --watch src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "zod": "^4.4.3"
  }
}
